# JWT secret for session tokens (REQUIRED - app will not start without this)
# Generate with: openssl rand -base64 32
JWT_SECRET=

# PortaBilling / Bicom API configuration (optional - demo data used if empty)
API_BASE_URL=https://your-portabilling-server.com/rest
API_KEY=your-api-key-here

# Tenant configuration (JSON map of username -> tenant details)
# Format: {"username": {"password_hash": "bcrypt_hash", "tenant_id": "123", "name": "Company Name"}}
# Generate password hashes with: node scripts/add-tenant.mjs <user> <pass> <id> <name>
TENANTS={}

# Allowed origins for iframe embedding (space-separated)
# Example: 'self' https://*.gohighlevel.com https://*.leadconnectorhq.com https://yourdomain.com
ALLOWED_FRAME_ORIGINS='self' https://*.gohighlevel.com https://*.leadconnectorhq.com
