# JWT secret for session tokens (generate a random string)
JWT_SECRET=your-secret-key-change-this

# PortaBilling / Bicom API configuration
API_BASE_URL=https://your-portabilling-server.com/rest
API_KEY=your-api-key-here

# Tenant configuration (JSON map of username -> tenant details)
# Format: {"username": {"password_hash": "bcrypt_hash", "tenant_id": "123", "name": "Company Name"}}
# Generate password hashes at: https://bcrypt-generator.com/
TENANTS={}
